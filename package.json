{
  "name": "crm-veloprime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "clean:next": "node scripts/clean-next-build.mjs",
    "build": "node scripts/run-prisma-migrate-if-db.mjs && prisma generate && next build",
    "build:clean": "npm run clean:next && npm run build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "node prisma/seed.mjs",
    "smoke:catalog-sync": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke-catalog-sync.ps1",
    "smoke:accounts": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke-account-flows.ps1",
    "smoke:lead-offer-online": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke-lead-offer-online.ps1",
    "smoke:public-offer-share": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke-public-offer-share.ps1",
    "smoke:offer-email": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\smoke-offer-email.ps1"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "@vercel/blob": "^1.1.1",
    "html2pdf.js": "^0.14.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "nodemailer": "^8.0.4",
    "prisma": "^6.15.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
