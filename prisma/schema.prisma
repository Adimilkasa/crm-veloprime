generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DIRECTOR
  MANAGER
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  OFFER_PREPARED
  NEGOTIATION
  WON
  LOST
}

enum LeadPipelineStage {
  NEW_LEAD
  FIRST_CONTACT
  FOLLOW_UP
  MEETING_SCHEDULED
  OFFER_SHARED
  WON
  LOST
  ON_HOLD
}

enum LeadDetailEntryKind {
  INFO
  COMMENT
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
  HIDDEN
}

enum OfferStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum CustomerType {
  PRIVATE
  BUSINESS
}

enum CommissionValueType {
  AMOUNT
  PERCENT
}

enum FinancingInputMode {
  AMOUNT
  PERCENT
}

enum OfferColorKind {
  BASE
  EXTRA_PAID
}

enum SalesModelStatus {
  ACTIVE
  ARCHIVED
}

enum PowertrainType {
  ELECTRIC
  HYBRID
  ICE
}

enum DriveType {
  FWD
  RWD
  AWD
}

enum SalesPricingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssetCategory {
  PRIMARY
  EXTERIOR
  INTERIOR
  DETAILS
  PREMIUM
  SPEC_PDF
  LOGO
  OTHER
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  isActive       Boolean       @default(true)
  phone          String?
  region         String?
  teamName       String?
  reportsToUserId String?
  reportsToUser  User?         @relation("UserHierarchy", fields: [reportsToUserId], references: [id])
  teamMembers    User[]        @relation("UserHierarchy")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  managedLeads   Lead[]        @relation("LeadManager")
  assignedLeads  Lead[]        @relation("LeadSalesOwner")
  leadDetailEntriesAuthored LeadDetailEntry[] @relation("LeadDetailEntryAuthor")
  customers      Customer[]
  offers         Offer[]
  commissionRulesOwned SalesCommissionRule[] @relation("CommissionRuleOwner")
  activityLogs   ActivityLog[]

  @@index([reportsToUserId])
}

model Customer {
  id            String      @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  companyName   String?
  taxId         String?
  city          String?
  notes         String?
  ownerId       String?
  owner         User?       @relation(fields: [ownerId], references: [id])
  leads         Lead[]
  offers        Offer[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Lead {
  id                String      @id @default(cuid())
  source            String
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  message           String?
  status            LeadStatus  @default(NEW)
  interestedModel   String?
  interestedVehicle String?
  region            String?
  pipelineStage     LeadPipelineStage @default(NEW_LEAD)
  managerId         String?
  manager           User?       @relation("LeadManager", fields: [managerId], references: [id])
  salespersonId     String?
  salesperson       User?       @relation("LeadSalesOwner", fields: [salespersonId], references: [id])
  nextActionAt      DateTime?
  customerId        String?
  customer          Customer?   @relation(fields: [customerId], references: [id])
  details           LeadDetailEntry[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([pipelineStage])
  @@index([salespersonId])
  @@index([updatedAt])
}

model LeadDetailEntry {
  id           String              @id @default(cuid())
  leadId       String
  lead         Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  kind         LeadDetailEntryKind @default(INFO)
  label        String
  value        String
  authorUserId String?
  authorUser   User?               @relation("LeadDetailEntryAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())

  @@index([leadId, createdAt])
}

model Vehicle {
  id             String         @id @default(cuid())
  stockNumber    String         @unique
  vin            String?        @unique
  brand          String
  model          String
  version        String?
  year           Int?
  bodyType       String?
  powertrain     String?
  color          String?
  mileageKm      Int?
  status         VehicleStatus  @default(AVAILABLE)
  availableFrom  DateTime?
  notes          String?
  pricing        VehiclePrice?
  offers         Offer[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VehiclePrice {
  id               String    @id @default(cuid())
  vehicleId        String    @unique
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  listPriceGross   Decimal?  @db.Decimal(12, 2)
  listPriceNet     Decimal?  @db.Decimal(12, 2)
  targetPriceGross Decimal?  @db.Decimal(12, 2)
  targetPriceNet   Decimal?  @db.Decimal(12, 2)
  minPriceGross    Decimal?  @db.Decimal(12, 2)
  minPriceNet      Decimal?  @db.Decimal(12, 2)
  cashPriceGross   Decimal?  @db.Decimal(12, 2)
  leaseMonthlyFrom Decimal?  @db.Decimal(12, 2)
  updatedAt        DateTime  @updatedAt
}

model BrandSetting {
  id                          String    @id @default(cuid())
  brand                       String    @unique
  defaultCurrency             String    @default("PLN")
  isActive                    Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  financingSetting            FinancingSetting?
  catalogItems                SalesCatalogItem[]
  colorPalettes               SalesModelColorPalette[]
}

model FinancingSetting {
  id                  String    @id @default(cuid())
  brandSettingId      String    @unique
  brandSetting        BrandSetting @relation(fields: [brandSettingId], references: [id], onDelete: Cascade)
  leaseTotalFactor    Decimal   @default(1.20) @db.Decimal(6, 4)
  disclaimerTemplate  String?
  allowedTermsJson    Json?
  buyoutLimitsJson    Json?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model SalesBrand {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  models     SalesModel[]

  @@index([sortOrder])
}

model SalesModel {
  id            String                @id @default(cuid())
  brandId       String
  brand         SalesBrand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  code          String
  name          String
  marketingName String?
  status        SalesModelStatus      @default(ACTIVE)
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  versions      SalesVersion[]
  colors        SalesModelColor[]
  assetBundle   SalesModelAssetBundle?

  @@unique([brandId, code])
  @@index([brandId, sortOrder])
  @@index([status])
}

model SalesVersion {
  id                      String               @id @default(cuid())
  modelId                 String
  model                   SalesModel           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  code                    String
  name                    String
  year                    Int?
  powertrainType          PowertrainType
  driveType               DriveType?
  systemPowerHp           Int?
  batteryCapacityKwh      Decimal?             @db.Decimal(8, 2)
  combustionEnginePowerHp Int?
  engineDisplacementCc    Int?
  rangeKm                 Int?
  notes                   String?
  sortOrder               Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  pricingRecords          SalesVersionPricing[]

  @@unique([modelId, code])
  @@index([modelId, sortOrder])
  @@index([powertrainType])
}

model SalesVersionPricing {
  id              String             @id @default(cuid())
  versionId       String
  version         SalesVersion       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  listPriceNet    Decimal            @db.Decimal(12, 2)
  listPriceGross  Decimal            @db.Decimal(12, 2)
  basePriceNet    Decimal            @db.Decimal(12, 2)
  basePriceGross  Decimal            @db.Decimal(12, 2)
  vatRate         Decimal            @default(23.00) @db.Decimal(5, 2)
  marginPoolNet   Decimal            @db.Decimal(12, 2)
  marginPoolGross Decimal            @db.Decimal(12, 2)
  pricingStatus   SalesPricingStatus @default(DRAFT)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([versionId, pricingStatus])
  @@index([effectiveFrom, effectiveTo])
}

model SalesModelColor {
  id             String      @id @default(cuid())
  modelId        String
  model          SalesModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  code           String
  name           String
  finishType     String?
  isBaseColor    Boolean     @default(false)
  hasSurcharge   Boolean     @default(false)
  surchargeNet   Decimal?    @db.Decimal(12, 2)
  surchargeGross Decimal?    @db.Decimal(12, 2)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([modelId, code])
  @@index([modelId, sortOrder])
}

model SalesModelAssetBundle {
  id               String          @id @default(cuid())
  modelId          String          @unique
  model            SalesModel      @relation(fields: [modelId], references: [id], onDelete: Cascade)
  assetsVersionTag String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  files            SalesAssetFile[]
}

model SalesAssetFile {
  id             String                @id @default(cuid())
  bundleId       String
  bundle         SalesModelAssetBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  category       AssetCategory
  powertrainType PowertrainType?
  fileName       String
  filePath       String
  fileDataBase64 String?
  mimeType       String?
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([bundleId, category, sortOrder])
  @@index([bundleId, powertrainType])
}

model SalesCatalogItem {
  id                 String    @id @default(cuid())
  brand              String
  model              String
  version            String
  year               String?
  powertrain         String?
  powerHp            String?
  baseColorName      String?
  listPriceGross     Decimal?  @db.Decimal(12, 2)
  listPriceNet       Decimal?  @db.Decimal(12, 2)
  basePriceGross     Decimal?  @db.Decimal(12, 2)
  basePriceNet       Decimal?  @db.Decimal(12, 2)
  isActive           Boolean   @default(true)
  brandSettingId     String?
  brandSetting       BrandSetting? @relation(fields: [brandSettingId], references: [id])
  colorPaletteId     String?
  colorPalette       SalesModelColorPalette? @relation(fields: [colorPaletteId], references: [id])
  commissionRules    SalesCommissionRule[]
  offers             Offer[]
  offerSnapshots     OfferSnapshot[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([brand, model, version, year])
  @@index([brand, model])
  @@index([isActive])
}

model SalesModelColorPalette {
  id                          String    @id @default(cuid())
  brand                       String
  model                       String
  baseColorName               String
  optionalColorSurchargeGross Decimal?  @db.Decimal(12, 2)
  optionalColorSurchargeNet   Decimal?  @db.Decimal(12, 2)
  isActive                    Boolean   @default(true)
  brandSettingId              String?
  brandSetting                BrandSetting? @relation(fields: [brandSettingId], references: [id])
  catalogItems                SalesCatalogItem[]
  colorOptions                SalesModelColorOption[]
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@unique([brand, model])
  @@index([brand])
}

model SalesModelColorOption {
  id                 String    @id @default(cuid())
  paletteId          String
  palette            SalesModelColorPalette @relation(fields: [paletteId], references: [id], onDelete: Cascade)
  colorName          String
  isBase             Boolean   @default(false)
  surchargeGross     Decimal?  @db.Decimal(12, 2)
  surchargeNet       Decimal?  @db.Decimal(12, 2)
  sortOrder          Int       @default(0)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([paletteId, colorName])
  @@index([paletteId, isActive])
}

model SalesCommissionRule {
  id                String               @id @default(cuid())
  ownerUserId       String
  ownerUser         User                 @relation("CommissionRuleOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  catalogItemId     String
  catalogItem       SalesCatalogItem     @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  valueType         CommissionValueType
  value             Decimal?             @db.Decimal(12, 4)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([ownerUserId, catalogItemId])
  @@index([ownerUserId, isActive])
}

model Offer {
  id                 String         @id @default(cuid())
  number             String         @unique
  status             OfferStatus    @default(DRAFT)
  title              String
  customerId         String
  customer           Customer       @relation(fields: [customerId], references: [id])
  vehicleId          String?
  vehicle            Vehicle?       @relation(fields: [vehicleId], references: [id])
  salesCatalogItemId String?
  salesCatalogItem   SalesCatalogItem? @relation(fields: [salesCatalogItemId], references: [id])
  ownerId            String
  owner              User           @relation(fields: [ownerId], references: [id])
  customerType       CustomerType   @default(PRIVATE)
  selectedColorKind  OfferColorKind @default(BASE)
  selectedColorName  String?
  colorSurchargeGross Decimal?      @db.Decimal(12, 2)
  colorSurchargeNet  Decimal?       @db.Decimal(12, 2)
  discountAmount     Decimal?       @db.Decimal(12, 2)
  discountPercent    Decimal?       @db.Decimal(7, 4)
  validUntil         DateTime?
  totalGross         Decimal?       @db.Decimal(12, 2)
  totalNet           Decimal?       @db.Decimal(12, 2)
  financingVariant   String?
  notes              String?
  currentSnapshot    OfferSnapshot?
  financing          OfferFinancing?
  versions           OfferVersion[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([salesCatalogItemId])
}

model OfferSnapshot {
  id                        String        @id @default(cuid())
  offerId                   String        @unique
  offer                     Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  salesCatalogItemId        String?
  salesCatalogItem          SalesCatalogItem? @relation(fields: [salesCatalogItemId], references: [id])
  customerType              CustomerType
  selectedColorKind         OfferColorKind
  selectedColorName         String?
  listPriceGross            Decimal?      @db.Decimal(12, 2)
  listPriceNet              Decimal?      @db.Decimal(12, 2)
  basePriceGross            Decimal?      @db.Decimal(12, 2)
  basePriceNet              Decimal?      @db.Decimal(12, 2)
  colorSurchargeGross       Decimal?      @db.Decimal(12, 2)
  colorSurchargeNet         Decimal?      @db.Decimal(12, 2)
  marginPoolGross           Decimal?      @db.Decimal(12, 2)
  marginPoolNet             Decimal?      @db.Decimal(12, 2)
  directorShareAmount       Decimal?      @db.Decimal(12, 2)
  managerShareAmount        Decimal?      @db.Decimal(12, 2)
  salespersonCommission     Decimal?      @db.Decimal(12, 2)
  availableDiscountAmount   Decimal?      @db.Decimal(12, 2)
  discountAmount            Decimal?      @db.Decimal(12, 2)
  discountPercent           Decimal?      @db.Decimal(7, 4)
  finalPriceGross           Decimal?      @db.Decimal(12, 2)
  finalPriceNet             Decimal?      @db.Decimal(12, 2)
  customerViewJson          Json?
  internalViewJson          Json?
  generatedAt               DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  @@index([salesCatalogItemId])
}

model OfferFinancing {
  id                         String             @id @default(cuid())
  offerId                    String             @unique
  offer                      Offer              @relation(fields: [offerId], references: [id], onDelete: Cascade)
  termMonths                 Int
  downPaymentInputMode       FinancingInputMode
  downPaymentInputValue      Decimal            @db.Decimal(12, 2)
  downPaymentAmount          Decimal?           @db.Decimal(12, 2)
  downPaymentPercent         Decimal?           @db.Decimal(7, 4)
  buyoutPercent              Decimal?           @db.Decimal(7, 4)
  buyoutAmount               Decimal?           @db.Decimal(12, 2)
  financedAssetValue         Decimal?           @db.Decimal(12, 2)
  leaseTotalFactor           Decimal?           @db.Decimal(6, 4)
  totalLeaseCost             Decimal?           @db.Decimal(12, 2)
  estimatedInstallment       Decimal?           @db.Decimal(12, 2)
  disclaimerText             String?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  @@index([termMonths])
}

model OfferVersion {
  id            String    @id @default(cuid())
  offerId       String
  offer         Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  versionNumber Int
  pdfUrl        String?
  shareToken    String?   @unique
  sharedAt      DateTime?
  shareExpiresAt DateTime?
  payloadJson   Json?
  customerSnapshotJson Json?
  internalSnapshotJson Json?
  createdAt     DateTime  @default(now())

  @@unique([offerId, versionNumber])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  entityType  String
  entityId    String
  action      String
  description String?
  payloadJson Json?
  createdAt   DateTime @default(now())
}