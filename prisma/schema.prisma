generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DIRECTOR
  MANAGER
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  OFFER_PREPARED
  NEGOTIATION
  WON
  LOST
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
  HIDDEN
}

enum OfferStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  isActive       Boolean       @default(true)
  phone          String?
  region         String?
  teamName       String?
  reportsToUserId String?
  reportsToUser  User?         @relation("UserHierarchy", fields: [reportsToUserId], references: [id])
  teamMembers    User[]        @relation("UserHierarchy")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  managedLeads   Lead[]        @relation("LeadManager")
  assignedLeads  Lead[]        @relation("LeadSalesOwner")
  customers      Customer[]
  offers         Offer[]
  activityLogs   ActivityLog[]

  @@index([reportsToUserId])
}

model Customer {
  id            String      @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  companyName   String?
  taxId         String?
  city          String?
  notes         String?
  ownerId       String?
  owner         User?       @relation(fields: [ownerId], references: [id])
  leads         Lead[]
  offers        Offer[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Lead {
  id                String      @id @default(cuid())
  source            String
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  message           String?
  status            LeadStatus  @default(NEW)
  interestedModel   String?
  interestedVehicle String?
  region            String?
  managerId         String?
  manager           User?       @relation("LeadManager", fields: [managerId], references: [id])
  salespersonId     String?
  salesperson       User?       @relation("LeadSalesOwner", fields: [salespersonId], references: [id])
  customerId        String?
  customer          Customer?   @relation(fields: [customerId], references: [id])
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Vehicle {
  id             String         @id @default(cuid())
  stockNumber    String         @unique
  vin            String?        @unique
  brand          String
  model          String
  version        String?
  year           Int?
  bodyType       String?
  powertrain     String?
  color          String?
  mileageKm      Int?
  status         VehicleStatus  @default(AVAILABLE)
  availableFrom  DateTime?
  notes          String?
  pricing        VehiclePrice?
  offers         Offer[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VehiclePrice {
  id               String    @id @default(cuid())
  vehicleId        String    @unique
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  listPriceGross   Decimal?  @db.Decimal(12, 2)
  listPriceNet     Decimal?  @db.Decimal(12, 2)
  targetPriceGross Decimal?  @db.Decimal(12, 2)
  targetPriceNet   Decimal?  @db.Decimal(12, 2)
  minPriceGross    Decimal?  @db.Decimal(12, 2)
  minPriceNet      Decimal?  @db.Decimal(12, 2)
  cashPriceGross   Decimal?  @db.Decimal(12, 2)
  leaseMonthlyFrom Decimal?  @db.Decimal(12, 2)
  updatedAt        DateTime  @updatedAt
}

model Offer {
  id                 String         @id @default(cuid())
  number             String         @unique
  status             OfferStatus    @default(DRAFT)
  title              String
  customerId         String
  customer           Customer       @relation(fields: [customerId], references: [id])
  vehicleId          String?
  vehicle            Vehicle?       @relation(fields: [vehicleId], references: [id])
  ownerId            String
  owner              User           @relation(fields: [ownerId], references: [id])
  validUntil         DateTime?
  totalGross         Decimal?       @db.Decimal(12, 2)
  totalNet           Decimal?       @db.Decimal(12, 2)
  financingVariant   String?
  notes              String?
  versions           OfferVersion[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model OfferVersion {
  id            String    @id @default(cuid())
  offerId       String
  offer         Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  versionNumber Int
  pdfUrl        String?
  payloadJson   Json?
  createdAt     DateTime  @default(now())

  @@unique([offerId, versionNumber])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation(fields: [actorId], references: [id])
  entityType  String
  entityId    String
  action      String
  description String?
  payloadJson Json?
  createdAt   DateTime @default(now())
}